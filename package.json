    "doj",
    "fda",
    "fact-check",
    "news",
    "osint",
    "intelligence",
    "thenexus"
  ],
  "homepage": "https://thenexus.news/developers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheNexusIntel/nexus-mcp.git"
  },
  "bugs": {
    "url": "https://thenexus.news/contact"
  },
  "author": "The Nexus (https://thenexus.news)",
